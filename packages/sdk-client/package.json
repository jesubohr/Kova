{
  "name": "@onkova/sdk-client",
  "version": "0.1.1",
  "description": "Kova client SDK — fetch wrapper that auto-pays x402 paywalls on Stellar",
  "license": "Apache-2.0",
  "keywords": [
    "x402",
    "stellar",
    "soroban",
    "micropayments",
    "usdc",
    "http",
    "fetch",
    "paywall",
    "ai-agent",
    "web3",
    "blockchain",
    "kova"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "13.1.0"
  },
  "devDependencies": {
    "typescript": "6.0.2",
    "tsup": "8.4.0",
    "@types/node": "22.14.0",
    "vitest": "4.1.4"
  }
}
