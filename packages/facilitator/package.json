{
  "name": "kova-facilitator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "cross-env FACILITATOR_STELLAR_SECRET=STEST KOVA_TREASURY_ADDRESS=GTEST DATABASE_URL=postgresql://test:test@localhost:5432/kova_test vitest run",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@fastify/cors": "11.0.0",
    "@fastify/rate-limit": "10.3.0",
    "@stellar/stellar-sdk": "15.0.1",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.0",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "@types/node": "22.14.0",
    "cross-env": "10.1.0",
    "tsup": "8.4.0",
    "tsx": "4.19.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
