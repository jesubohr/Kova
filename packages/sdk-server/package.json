{
  "name": "@onkova/sdk-server",
  "version": "0.1.0",
  "description": "Kova server SDK — Fastify/Express middleware for x402 API paywalls on Stellar",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "13.1.0",
    "fastify-plugin": "5.1.0"
  },
  "peerDependencies": {
    "express": "4.0.0 || ^5.0.0",
    "fastify": "5.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "22.14.0",
    "@types/supertest": "7.2.0",
    "cross-env": "10.1.0",
    "express": "5.1.0",
    "fastify": "5.3.0",
    "supertest": "7.2.2",
    "tsup": "8.4.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}

